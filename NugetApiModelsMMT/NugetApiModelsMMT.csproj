<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <Title>Modelos de Api</Title>
    <Authors>$(AssemblyName),Nuget,Api,Models,MMT</Authors>
    <Description>Modelos de Api</Description>
    <PackageIcon>gallina.jpg</PackageIcon>
    <PackageTags>Nuget;Api;Models;MMT</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <None Update="gallina.jpg">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>
